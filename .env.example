# Required - Google Gemini API key for image generation
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required - FAL AI key for background removal and 3D model generation
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=

# Optional - Anthropic API key for Kiln 3D primitives via Claude
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional - Server port (default: 3000)
PORT=3000
