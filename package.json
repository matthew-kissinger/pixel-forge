{
  "name": "pixel-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Matthew Kissinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthew-kissinger/pixel-forge.git"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --filter client dev",
    "dev:server": "bun run --filter server dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:e2e": "playwright test",
    "check:bundle-size": "bun run scripts/check-bundle-size.ts",
    "audit:glb": "tsx scripts/visual-audit.ts",
    "audit:review": "bun scripts/audit-review-page.ts --open"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "sharp": "^0.34.5"
  }
}
